        { source: 'Claude', action: 'upgrade', value: 299, time: '8m ago' },
        { source: 'Perplexity', action: 'signup', value: 99, time: '15m ago' },
        { source: 'ChatGPT', action: 'signup', value: 99, time: '23m ago' },
