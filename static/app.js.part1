                    <div style="flex:1;background:var(--color-border);border-radius:4px;height:6px">
                      <div style="width:${c.aiScore}%;height:6px;border-radius:4px;background:${c.name === 'YOU' ? '#00c8ff' : '#7c3aed'}"></div>
                    </div>
                    <span>${c.aiScore}</span>
                  </div>
                </td>
                <td style="color:#10b981">${c.trend}</td>
